# =============================================================================
# Frontend Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in the actual values
# All variables marked as REQUIRED must be set for the application to start
# Note: Next.js requires NEXT_PUBLIC_ prefix for client-side variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------

# Supabase project URL
# REQUIRED
# Get this from: Supabase Dashboard > Project Settings > API
# This is safe to expose in client-side code
# Example: https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous (public) key
# REQUIRED
# Get this from: Supabase Dashboard > Project Settings > API
# This key is safe to use in client-side code
# It only allows operations permitted by Row Level Security policies
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# Backend API base URL
# REQUIRED
# The URL where your Express backend is running
# Example (development): http://localhost:3001
# Example (production): https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# API version prefix
# Default: /api/v1
# Example: /api/v1
NEXT_PUBLIC_API_VERSION=/api/v1

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Application name
# Default: AI Software Engineering Monitoring Platform
# Example: AI Software Engineering Monitoring Platform
NEXT_PUBLIC_APP_NAME=AI Software Engineering Monitoring Platform

# Application short name
# Default: AI Monitor
# Example: AI Monitor
NEXT_PUBLIC_APP_SHORT_NAME=AI Monitor

# Application URL (used for OAuth redirects and metadata)
# Example (development): http://localhost:3000
# Example (production): https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable real-time updates via Socket.IO
# Default: true
# Example: true
NEXT_PUBLIC_ENABLE_REALTIME=true

# Enable dark mode
# Default: true
# Example: true
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# Enable onboarding flow for new users
# Default: true
# Example: true
NEXT_PUBLIC_ENABLE_ONBOARDING=true

# -----------------------------------------------------------------------------
# Socket.IO Configuration
# -----------------------------------------------------------------------------

# Socket.IO server URL (usually same as API URL)
# Default: Same as NEXT_PUBLIC_API_URL
# Example: http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Socket.IO path
# Default: /socket.io
# Example: /socket.io
NEXT_PUBLIC_SOCKET_PATH=/socket.io

# Socket.IO reconnection attempts
# Default: 5
# Example: 5
NEXT_PUBLIC_SOCKET_RECONNECTION_ATTEMPTS=5

# Socket.IO reconnection delay in milliseconds
# Default: 1000
# Example: 1000
NEXT_PUBLIC_SOCKET_RECONNECTION_DELAY=1000

# -----------------------------------------------------------------------------
# GitHub Configuration
# -----------------------------------------------------------------------------

# GitHub OAuth redirect URI
# Must match the callback URL configured in your GitHub OAuth App
# Example (development): http://localhost:3000/auth/callback
# Example (production): https://your-domain.com/auth/callback
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback

# -----------------------------------------------------------------------------
# Analytics Configuration (Optional)
# -----------------------------------------------------------------------------

# Google Analytics Measurement ID
# Optional: Leave empty to disable analytics
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Sentry DSN for error tracking
# Optional: Leave empty to disable error tracking
# Example: https://your-key@sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# UI Configuration
# -----------------------------------------------------------------------------

# Default theme (light, dark, system)
# Default: system
# Example: system
NEXT_PUBLIC_DEFAULT_THEME=system

# Items per page for pagination
# Default: 20
# Example: 20
NEXT_PUBLIC_ITEMS_PER_PAGE=20

# Repository search results per page
# Default: 30
# Example: 30
NEXT_PUBLIC_REPO_SEARCH_LIMIT=30

# Toast notification duration in milliseconds
# Default: 5000
# Example: 5000
NEXT_PUBLIC_TOAST_DURATION=5000

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------

# React Query stale time in milliseconds
# How long data is considered fresh before refetching
# Default: 300000 (5 minutes)
# Example: 300000
NEXT_PUBLIC_QUERY_STALE_TIME=300000

# React Query cache time in milliseconds
# How long unused data stays in cache
# Default: 600000 (10 minutes)
# Example: 600000
NEXT_PUBLIC_QUERY_CACHE_TIME=600000

# Repository list cache time in milliseconds
# Default: 300000 (5 minutes)
# Example: 300000
NEXT_PUBLIC_REPO_CACHE_TIME=300000

# -----------------------------------------------------------------------------
# Development Configuration
# -----------------------------------------------------------------------------

# Enable debug mode (shows additional logging in console)
# Default: false
# Example: true (development), false (production)
NEXT_PUBLIC_DEBUG=false

# Enable mock data for development
# Default: false
# Example: true
NEXT_PUBLIC_ENABLE_MOCK_DATA=false

# API request timeout in milliseconds
# Default: 30000
# Example: 30000
NEXT_PUBLIC_API_TIMEOUT=30000
